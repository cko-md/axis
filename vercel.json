{
  "framework": "nextjs",
  "ignoreCommand": "sh -c 'sh scripts/vercel-ignore-build.sh; status=$?; if [ \"$status\" -eq 74 ]; then exit 1; fi; exit 0'",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/finance-daily",
      "schedule": "0 22 * * *"
    }
  ]
}
