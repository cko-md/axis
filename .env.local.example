# Supabase (required for auth + data sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# App URL (OAuth redirects — Spotify, auth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Sentry (optional locally; set in Vercel preview/production for observability)
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN is used by @sentry/nextjs source-map upload in CI/Vercel.
SENTRY_AUTH_TOKEN=

# Composio (optional provider transport for Gmail/Outlook/Calendar/etc.)
COMPOSIO_API_KEY=

# Direct Google/Microsoft OAuth (Mail, Calendar, Contacts)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Polygon.io / Massive market data (server-side only; either key works)
POLYGON_API_KEY=
MASSIVE_API_KEY=

# Plaid (Fund banking; optional)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Spotify Web API (Listening Vault + sidebar miniplayer)
# Register app at https://developer.spotify.com/dashboard
# Redirect URI: http://localhost:3000/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Strava API — powers Vitality / Running tab (live mileage, pace, activity feed)
# Register app at https://www.strava.com/settings/api
# Redirect URI: http://localhost:3000/api/strava?action=callback
# Server-side only — never use NEXT_PUBLIC_ prefix for these
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Anthropic API — powers AI capture classification and signal triage
# Get a key at https://console.anthropic.com
# If unset, the /api/ai route falls back to heuristic classification (no error)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
TAVILY_API_KEY=

# Make / cron / rate-limit integrations (optional; features degrade if unset)
MAKE_API_KEY=
MAKE_TEAM_ID=
MAKE_ZONE=us2.make.com
MAKE_SWEEP_SECRET=
MAKE_WEBHOOK_SECRET=
MAKE_WEBHOOK_DAILY_BRIEF_URL=
MAKE_WEBHOOK_WEEKLY_RECAP_URL=
MAKE_WEBHOOK_BILL_REMINDER_URL=
MAKE_WEBHOOK_BUDGET_ALERT_URL=
MAKE_WEBHOOK_ANOMALY_ALERT_URL=
MAKE_WEBHOOK_SUBSCRIPTION_AUDIT_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CRON_SECRET=
FEED_DIGEST_SECRET=

# Passkeys / health / brokerage (optional)
PASSKEY_ENCRYPTION_KEY=
GARMIN_CLIENT_ID=
OURA_CLIENT_ID=
FITBIT_CLIENT_ID=
WHOOP_CLIENT_ID=
BROKERAGE_API_KEY=
BROKERAGE_ACCOUNT_ID=
