{
  "name": "axis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build",
    "postbuild": "node scripts/build-vector-offline-bootstrap.mjs && node scripts/generate-vector-offline-manifests.mjs",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test --project=public",
    "test:e2e:auth": "AXIS_E2E_AUTH=1 playwright test --project=authenticated",
    "release:validate": "node scripts/validate-release-wave.mjs",
    "desktop:dev": "electron electron/main.cjs --dev",
    "desktop:start": "electron electron/main.cjs",
    "desktop:test": "node --test electron/*.test.cjs",
    "desktop:check": "node scripts/check-electron-version.mjs && node scripts/check-desktop-security.mjs && npm run desktop:test",
    "desktop:check:current": "node scripts/check-electron-current.mjs",
    "desktop:dist": "npm run desktop:check && electron-builder --projectDir electron --config electron-builder.cjs",
    "desktop:dist:dir": "npm run desktop:check && electron-builder --projectDir electron --config electron-builder.cjs --dir",
    "desktop:preview:validate": "node scripts/validate-desktop-preview.mjs",
    "desktop:release": "npm run desktop:check && node scripts/validate-desktop-release.mjs && electron-builder --projectDir electron --config electron-builder.cjs",
    "desktop:size": "node scripts/report-desktop-size.mjs",
    "desktop:size:check": "node scripts/report-desktop-size.mjs --check",
    "desktop:secrets:check": "node scripts/check-desktop-release-secrets.mjs",
    "desktop:secrets:configure": "node scripts/configure-desktop-release-secrets.mjs",
    "desktop:apple-signing:check": "node scripts/check-desktop-release-secrets.mjs --platform apple",
    "desktop:apple-signing:configure": "node scripts/configure-desktop-release-secrets.mjs",
    "desktop:windows-signing:check": "node scripts/check-desktop-release-secrets.mjs --platform windows",
    "desktop:windows-signing:configure": "node scripts/configure-windows-signing.mjs",
    "axis": "node scripts/axis.mjs",
    "state:derive": "node scripts/derive-program-state.mjs",
    "state:derive:gates": "node scripts/derive-program-state.mjs --gates",
    "state:check": "node scripts/derive-program-state.mjs --check"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@formkit/auto-animate": "^0.9.0",
    "@mozilla/readability": "^0.6.0",
    "@sentry/nextjs": "^10.59.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.49.8",
    "@tiptap/extension-code-block-lowlight": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "isomorphic-dompurify": "^3.18.0",
    "jsdom": "^26.0.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^6.0.2",
    "react-plaid-link": "^4.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "fake-indexeddb": "^6.2.5",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@sentry/cli@2.58.6": true,
    "electron@43.1.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
