# Sentry auth token (contains secrets)
.env.sentry-build-plugin

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.auth

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/certificates/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.superdesign

# claude code local-only state
.claude/workflows/
.claude/settings.local.json
.claude/worktrees/

# personal scratch scripts — not part of the app, not meant to be checked in
agent.py
test-results

# desktop preview (Electron) build output — regenerated installers (~800MB).
# The electron/ source itself lives on codex/electron-preview-release (PR #227)
# and will track normally when that branch lands.
dist-electron/

# electron sub-package install + generated icons (built locally / in CI)
electron/node_modules/
electron/build/icon.iconset/

# VECTOR per-build offline manifests (scripts/generate-vector-offline-manifests.mjs
# regenerates these fresh on every real build, keyed by that build's exact
# buildId; only the committed development-empty build-map.json is tracked)
/public/vector-assets/manifests/*.json
!/public/vector-assets/manifests/build-map.json

# VECTOR offline standalone bootstrap bundle(s) — esbuild output regenerated
# by scripts/build-vector-offline-bootstrap.mjs on every `npm run build`
# (source: src/lib/vector/games/*/offline-bootstrap.ts). The static HTML
# shell next to these files (offline/*.html) IS hand-authored source and
# stays tracked.
/public/vector-assets/offline/*.js
